# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/model_arena
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=model_arena

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Service URLs (for local development)
MODEL_REGISTRY_URL=http://localhost:8001
ARENA_SERVICE_URL=http://localhost:8002
TOURNAMENT_SERVICE_URL=http://localhost:8003
MONITORING_SERVICE_URL=http://localhost:8004
TEAM_SERVICE_URL=http://localhost:8005

# HuggingFace Configuration
HF_HOME=/app/hf_cache
HF_TOKEN=your_huggingface_token_here

# API Configuration
API_RATE_LIMIT=100
API_RATE_LIMIT_PERIOD=60

# Security
SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Model Loading
MAX_MODEL_SIZE_GB=10
MODEL_CACHE_DIR=/tmp/model_cache
ENABLE_GPU=true
GPU_MEMORY_FRACTION=0.8

# Arena Configuration
DEFAULT_RENTAL_PRICE=10.0
MAX_RENTAL_DURATION_HOURS=24

# Tournament Configuration
MAX_TOURNAMENT_MODELS=16
DEFAULT_TOURNAMENT_TYPE=round_robin

# Monitoring
METRICS_RETENTION_DAYS=90
ENABLE_DETAILED_METRICS=true

# Development
DEBUG=false
RELOAD=false
